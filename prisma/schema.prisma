generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  PAUSED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  MAKEUP
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum MemoCategory {
  GENERAL
  PROGRESS
  ISSUE
  PARENT_CONTACT
  OTHER
}

// ─── Models ──────────────────────────────────────────────

model Student {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String        @db.VarChar(50)
  phone     String?       @db.VarChar(20)
  parentPhone String?     @map("parent_phone") @db.VarChar(20)
  school    String?       @db.VarChar(50)
  grade     String?       @db.VarChar(20)
  status    StudentStatus @default(ACTIVE)
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  subscriptions Subscription[]
  attendances   Attendance[]
  payments      Payment[]
  memos         Memo[]

  @@index([status])
  @@index([name])
  @@map("students")
}

model Subscription {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  daysPerWeek  Int      @map("days_per_week")
  scheduleDays String[] @map("schedule_days") @db.VarChar(3)
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  monthlyFee   Int      @map("monthly_fee")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([isActive])
  @@map("subscriptions")
}

model Attendance {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String           @map("student_id") @db.Uuid
  date      DateTime         @db.Date
  status    AttendanceStatus
  checkInAt DateTime?        @map("check_in_at")
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@index([studentId, date])
  @@map("attendance")
}

model Payment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId     String        @map("student_id") @db.Uuid
  amount        Int
  method        PaymentMethod?
  status        PaymentStatus @default(PENDING)
  targetMonth   String        @map("target_month") @db.VarChar(7)
  paidAt        DateTime?     @map("paid_at")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([targetMonth])
  @@index([status])
  @@map("payments")
}

model Memo {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String       @map("student_id") @db.Uuid
  category  MemoCategory @default(GENERAL)
  content   String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([createdAt])
  @@map("memos")
}
